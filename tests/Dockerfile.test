FROM python:3.12-slim
WORKDIR /workspace
RUN apt-get update && apt-get install -y curl git gcc librdkafka-dev && rm -rf /var/lib/apt/lists/*
COPY . /workspace
RUN pip install --upgrade pip setuptools wheel
RUN pip install -r ingestion-service/requirements.txt
RUN pip install -r evidence-service/requirements.txt
# install shared package
RUN pip install ./shared
CMD ["pytest", "-q"]
